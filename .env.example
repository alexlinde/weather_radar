# Optional: map tile API key for richer base map styles
# Stadia Maps (Stamen Terrain) — https://stadiamaps.com
STADIA_API_KEY=

# MapTiler Outdoor — https://www.maptiler.com
MAPTILER_API_KEY=

# If both are empty, the app falls back to OpenFreeMap (no key needed)

# Data cache directory (default: ./data relative to project root)
# DATA_DIR=/tmp/data

# In-memory tilt cache entries (default: 30, ~39 MB each)
# TILT_CACHE_SIZE=30

# In-memory tile cache entries (default: 2000, ~5-10 KB each)
# TILE_CACHE_SIZE=2000
